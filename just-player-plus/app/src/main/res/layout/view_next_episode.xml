<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/next_episode_card"
    android:layout_width="460dp"
    android:layout_height="190dp"
    android:layout_gravity="end|bottom"
    android:layout_marginEnd="48dp"
    android:layout_marginBottom="48dp"
    android:background="@drawable/next_episode_card_background"
    android:elevation="16dp"
    android:visibility="gone">

    <ImageView
        android:id="@+id/next_episode_artwork"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.82"
        android:contentDescription="@null"
        android:scaleType="centerCrop" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/next_episode_scrim" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="18dp"
        android:paddingEnd="22dp"
        android:paddingBottom="18dp">

        <TextView
            android:id="@+id/next_episode_series_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#FFFFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/next_episode_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#FFE1E4EB"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="start|center_vertical"
            android:orientation="horizontal"
            tools:ignore="ButtonStyle">

            <Button
                android:id="@+id/next_episode_play_now"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:background="@drawable/next_episode_primary_button"
                android:drawableStart="@drawable/ic_play_arrow_24dp"
                android:drawablePadding="6dp"
                android:drawableTint="#FF171923"
                android:focusable="true"
                android:fontFamily="sans"
                android:minWidth="138dp"
                android:nextFocusRight="@id/next_episode_dismiss"
                android:paddingStart="14dp"
                android:paddingEnd="16dp"
                android:text="@string/next_episode_play_now"
                android:textAllCaps="false"
                android:textColor="@color/next_episode_primary_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/next_episode_dismiss"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/next_episode_secondary_button"
                android:focusable="true"
                android:fontFamily="sans"
                android:minWidth="105dp"
                android:nextFocusLeft="@id/next_episode_play_now"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/next_episode_dismiss"
                android:textAllCaps="false"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
